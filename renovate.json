{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>containerbase/.github:renovate-config"],
  "packageRules": [
    {
      "description": "Use `chore` semantic commit scope for lockfile maintenance.",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "semanticCommitType": "chore"
    }
  ]
}
